    <item>
      <title>Approach</title>
      <link>http://localhost:1313/approach/</link>
      <pubDate>Mon, 01 Jan 0001 00:00:00 +0000</pubDate>
      <guid>http://localhost:1313/approach/</guid>
      <description>&lt;p&gt;My artistic approach focuses on capturing the essence and personality of each subject. I work primarily in acrylics, oils, and watercolours, each medium bringing its own character to the portrait.&lt;/p&gt;&#xA;&lt;p&gt;&lt;em&gt;This page is coming soon � check back for more about my process.&lt;/em&gt;&lt;/p&gt;</description>
