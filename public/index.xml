      <link>http://localhost:1313/biography/</link>
      <pubDate>Mon, 01 Jan 0001 00:00:00 +0000</pubDate>
      <guid>http://localhost:1313/biography/</guid>
      <description>&lt;style&gt;&#xA;.bio-container {&#xA;  max-width: 90%;&#xA;  margin: 0 auto;&#xA;  display: flex;&#xA;  gap: 3rem;&#xA;  align-items: flex-start;&#xA;}&#xA;.bio-photo {&#xA;  width: 40%;&#xA;  flex-shrink: 0;&#xA;  border-radius: 8px;&#xA;  box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);&#xA;}&#xA;.bio-text {&#xA;  text-align: left;&#xA;}&#xA;.bio-text p {&#xA;  margin-bottom: 1.2rem;&#xA;  font-size: 1.1rem;&#xA;  line-height: 1.9;&#xA;}&#xA;.bio-text h2 {&#xA;  font-family: &#39;Cormorant Garamond&#39;, serif;&#xA;  font-size: 2rem;&#xA;  font-weight: 300;&#xA;  margin-bottom: 1.5rem;&#xA;  color: #EDBFC6;&#xA;}&#xA;.bio-detail {&#xA;  font-size: 0.95rem;&#xA;  color: #AF8D86;&#xA;  font-style: italic;&#xA;  margin-top: 2rem;&#xA;}&#xA;&#xA;@media (max-width: 768px) {&#xA;  .bio-container {&#xA;    flex-direction: column;&#xA;    align-items: center;&#xA;  }&#xA;  .bio-photo {&#xA;    width: 100%;&#xA;    max-width: 400px;&#xA;  }&#xA;  .bio-text {&#xA;    text-align: center;&#xA;  }&#xA;}&#xA;&lt;/style&gt;&#xA;&lt;div class=&#34;bio-container&#34;&gt;&#xA;&lt;img src=&#34;http://localhost:1313/images/gemma.jpg&#34; alt=&#34;Gemma Quinn&#34; class=&#34;bio-photo&#34;&gt;&#xA;&lt;div class=&#34;bio-text&#34;&gt;&#xA;&lt;h2&gt;About Gemma&lt;/h2&gt;&#xA;&lt;p&gt;Gemma Quinn is a portrait artist based in London, UK.&lt;/p&gt;</description>
