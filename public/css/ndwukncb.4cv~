:root {
    --light-pink: #FAE3E3;
    --peach: #F7D4BC;
    --dusty-rose: #CFA5B4;
    --purple-pink: #C98BB9;
    --muted-purple: #846B8A;
}

/* Base styles */
body {
    background-color: var(--light-pink);
    color: var(--muted-purple);
    font-family: 'Helvetica Neue', sans-serif;
}

/* Headings */
h1, h2, h3, h4, h5, h6 {
    color: var(--muted-purple);
}

/* Links */
a {
    color: var(--purple-pink);
    text-decoration: none;
}

    a:hover {
        color: var(--dusty-rose);
        text-decoration: underline;
    }

/* Header / Navigation */
header.site-header, nav {
    background-color: var(--muted-purple);
    color: white;
}

    nav a {
        color: white;
    }

        nav a:hover {
            color: var(--peach);
        }

/* Hero section (the large "Home" area) */
.button {
    background-color: var(--muted-purple);
    color: var(--peach);
}

    .hero h1 {
        color: var(--peach);
    }

/* Buttons */
button,
.button {
    background-color: var(--purple-pink);
    color: white;
    border: none;
    padding: 0.5em 1em;
    border-radius: 8px;
}

    button:hover,
    .button:hover {
        background-color: var(--dusty-rose);
    }

/* Gallery images */
.gallery img {
    border: 4px solid var(--peach);
    border-radius: 8px;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
}

    .gallery img:hover {
        transform: scale(1.03);
        box-shadow: 0 0 10px var(--dusty-rose);
    }

/* Footer */
footer {
    background-color: var(--muted-purple);
    color: white;
    padding: 1em;
    text-align: center;
}

/* Optional: code blocks, blockquotes */
pre, code {
    background-color: var(--peach);
    color: var(--muted-purple);
}

blockquote {
    border-left: 4px solid var(--dusty-rose);
    padding-left: 1em;
    color: var(--muted-purple);
    background-color: var(--light-pink);
}
